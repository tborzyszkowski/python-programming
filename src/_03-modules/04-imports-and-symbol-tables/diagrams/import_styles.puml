@startuml
skinparam monochrome true
skinparam shadowing false

actor User
rectangle "module A" as A
rectangle "module B" as B
rectangle "builtins" as BI

User --> A : import B
A --> B : name B in globals()
User --> A : from B import f
A --> A : name f in globals()
A --> BI : fallback lookup (LEGB -> builtins)
@enduml


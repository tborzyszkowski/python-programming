@startuml
title Przechwytywanie grup

skinparam sequence {
    ParticipantBackgroundColor LightYellow
    ParticipantBorderColor DarkOrange
    ArrowColor DarkBlue
}

participant Napis as S
participant Silnik as E
participant Match as M

S -> E : re.search(pattern, s)
activate E

E -> E : dopasuj rok (grupa 1)
E -> E : dopasuj separator
E -> E : dopasuj miesiac (grupa 2)
E -> E : dopasuj separator
E -> E : dopasuj dzien (grupa 3)

E -> M : utworz Match object
deactivate E

M --> S : .group(0) cale dopasowanie
M --> S : .group(1) rok
M --> S : .group("rok") nazwana
M --> S : .group("m") miesiac
M --> S : .group("d") dzien
M --> S : .groupdict() slownik

note over M
  Grupy numerowane od 1.
  group(0) = cale dopasowanie.
  Nazwane grupy dostepne
  przez .group("name")
  lub .groupdict().
end note

@enduml
